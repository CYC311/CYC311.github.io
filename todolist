<!DOCTYPE html>\n<html lang="en">\n<head>\n    <meta charset="UTF-8">\n    <meta name="viewport" content="width=device-width, initial-scale=1.0">\n    <title>Todo List Application</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f4f4f4;\n            margin: 0;\n            padding: 20px;\n        }\n        #todo-form {\n            margin-bottom: 20px;\n        }\n        #todo-list {\n            list-style: none;\n            padding: 0;\n        }\n        .todo-item {\n            background: white;\n            margin: 5px 0;\n            padding: 10px;\n            border-radius: 5px;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n        }\n    </style>\n</head>\n<body>\n    <h1>Todo List</h1>\n    <form id="todo-form">\n        <input type="text" id="task" placeholder="Add new task..." required>\n        <input type="date" id="due-date">\n        <select id="priority">\n            <option value="low">Low</option>\n            <option value="medium">Medium</option>\n            <option value="high">High</option>\n        </select>\n        <button type="submit">Add Task</button>\n    </form>\n    <ul id="todo-list"></ul>\n    <script>\n        const form = document.getElementById('todo-form');\n        const taskInput = document.getElementById('task');\n        const dueDateInput = document.getElementById('due-date');\n        const priorityInput = document.getElementById('priority');\n        const todoList = document.getElementById('todo-list');\n\n        let todos = JSON.parse(localStorage.getItem('todos')) || [];\n\n        function renderTodos() {\n            todoList.innerHTML = '';\n            todos.forEach((todo, index) => {\n                const todoItem = document.createElement('li');\n                todoItem.className = 'todo-item';\n                todoItem.innerHTML = `<span>${todo.task} - ${todo.dueDate} - ${todo.priority}</span> <button onclick="deleteTask(${index})">Delete</button>`;\n                todoList.appendChild(todoItem);\n            });\n        }\n\n        form.addEventListener('submit', function (event) {\n            event.preventDefault();\n            const newTodo = {\n                task: taskInput.value,\n                dueDate: dueDateInput.value || 'No due date',\n                priority: priorityInput.value\n            };\n            todos.push(newTodo);\n            localStorage.setItem('todos', JSON.stringify(todos));\n            taskInput.value = '';\n            dueDateInput.value = '';\n            renderTodos();\n        });\n\n        window.deleteTask = function(index) {\n            todos.splice(index, 1);\n            localStorage.setItem('todos', JSON.stringify(todos));\n            renderTodos();\n        };\n\n        renderTodos();\n    <\/script>\n</body>\n</html>
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>我的待辦事項管理器</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Microsoft YaHei', 'Noto Sans CJK TC', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
        }

        header {
            text-align: center;
            color: white;
            margin-bottom: 30px;
        }

        header h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
        }

        header p {
            font-size: 1.1rem;
            opacity: 0.9;
        }

        .main-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        .card {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }

        .card h2 {
            color: #333;
            margin-bottom: 15px;
            font-size: 1.3rem;
            border-bottom: 3px solid #667eea;
            padding-bottom: 10px;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 15px;
        }

        .input-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        label {
            font-weight: bold;
            color: #555;
            font-size: 0.95rem;
        }

        input[type="text"],
        input[type="date"],
        select {
            padding: 12px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 1rem;
            font-family: inherit;
            transition: border-color 0.3s;
        }

        input[type="text"]:focus,
        input[type="date"]:focus,
        select:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 5px rgba(102, 126, 234, 0.3);
        }

        select {
            cursor: pointer;
        }

        .button-group {
            display: flex;
            gap: 10px;
        }

        button {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-add {
            background: #667eea;
            color: white;
        }

        .btn-add:hover {
            background: #5568d3;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-reset {
            background: #ecf0f1;
            color: #555;
        }

        .btn-reset:hover {
            background: #d5dbdb;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-top: 20px;
        }

        .stat-box {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px;
            border-radius: 10px;
            text-align: center;
        }

        .stat-box .number {
            font-size: 2rem;
            font-weight: bold;
        }

        .stat-box .label {
            font-size: 0.9rem;
            opacity: 0.9;
        }

        .filter-group {
            display: flex;
            gap: 8px;
            margin-bottom: 15px;
            flex-wrap: wrap;
        }

        .filter-btn {
            padding: 8px 15px;
            border: 2px solid #e0e0e0;
            background: white;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 0.9rem;
            font-weight: 500;
        }

        .filter-btn.active {
            background: #667eea;
            color: white;
            border-color: #667eea;
        }

        .filter-btn:hover {
            border-color: #667eea;
        }

        .tasks-list {
            max-height: 500px;
            overflow-y: auto;
        }

        .task-item {
            background: #f8f9fa;
            padding: 15px;
            margin-bottom: 12px;
            border-radius: 10px;
            border-left: 4px solid #667eea;
            display: flex;
            align-items: start;
            gap: 12px;
            transition: all 0.3s;
        }

        .task-item.completed {
            opacity: 0.6;
            background: #e8f5e9;
            border-left-color: #4caf50;
        }

        .task-item.completed .task-content h3 {
            text-decoration: line-through;
            color: #999;
        }

        .task-item:hover {
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
        }

        .checkbox-wrapper {
            margin-top: 3px;
        }

        .checkbox-wrapper input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }

        .task-content {
            flex: 1;
        }

        .task-content h3 {
            color: #333;
            margin-bottom: 5px;
            word-break: break-word;
        }

        .task-meta {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 8px;
            font-size: 0.85rem;
        }

        .badge {
            padding: 4px 10px;
            border-radius: 12px;
            font-weight: bold;
            display: inline-block;
        }

        .badge-priority {
            color: white;
        }

        .badge-priority.high {
            background: #ff6b6b;
        }

        .badge-priority.medium {
            background: #ffd93d;
            color: #333;
        }

        .badge-priority.low {
            background: #6bcf7f;
        }

        .badge-category {
            background: #e3f2fd;
            color: #1976d2;
            border: 1px solid #1976d2;
        }

        .badge-date {
            background: #f3e5f5;
            color: #7b1fa2;
            border: 1px solid #7b1fa2;
        }

        .task-actions {
            display: flex;
            gap: 5px;
        }

        .btn-small {
            padding: 6px 10px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.85rem;
            transition: all 0.3s;
        }

        .btn-edit {
            background: #2196f3;
            color: white;
        }

        .btn-edit:hover {
            background: #1565c0;
        }

        .btn-delete {
            background: #ff6b6b;
            color: white;
        }

        .btn-delete:hover {
            background: #e63946;
        }

        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: #999;
        }

        .empty-state svg {
            width: 80px;
            height: 80px;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: white;
            padding: 30px;
            border-radius: 15px;
            max-width: 500px;
            width: 90%;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }

        .modal-header {
            font-size: 1.5rem;
            font-weight: bold;
            color: #333;
            margin-bottom: 20px;
            border-bottom: 2px solid #667eea;
            padding-bottom: 10px;
        }

        .modal-buttons {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        .modal-buttons button {
            flex: 1;
            padding: 12px;
        }

        .modal-buttons .btn-cancel {
            background: #ecf0f1;
            color: #555;
        }

        .modal-buttons .btn-cancel:hover {
            background: #d5dbdb;
        }

        .modal-buttons .btn-save {
            background: #667eea;
            color: white;
        }

        .modal-buttons .btn-save:hover {
            background: #5568d3;
        }

        @media (max-width: 768px) {
            .main-content {
                grid-template-columns: 1fr;
            }

            header h1 {
                font-size: 2rem;
            }

            .stats {
                grid-template-columns: 1fr;
            }

            .input-row {
                grid-template-columns: 1fr;
            }
        }

        .tasks-scroll::-webkit-scrollbar {
            width: 8px;
        }

        .tasks-scroll::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        .tasks-scroll::-webkit-scrollbar-thumb {
            background: #667eea;
            border-radius: 10px;
        }

        .tasks-scroll::-webkit-scrollbar-thumb:hover {
            background: #5568d3;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>📝 我的待辦事項</h1>
            <p>讓生活更有條理，一個任務一個時刻</p>
        </header>

        <div class="main-content">
            <!-- 左側：新增任務 -->
            <div class="card">
                <h2>✨ 新增任務</h2>
                <div class="input-group">
                    <div>
                        <label for="taskInput">任務標題 *</label>
                        <input type="text" id="taskInput" placeholder="輸入你的任務..." maxlength="100">
                    </div>

                    <div>
                        <label for="categorySelect">分類</label>
                        <select id="categorySelect">
                            <option value="工作">🏢 工作</option>
                            <option value="學習">📚 學習</option>
                            <option value="健康">💪 健康</option>
                            <option value="生活">🏠 生活</option>
                            <option value="購物">🛍️ 購物</option>
                            <option value="娛樂">🎮 娛樂</option>
                            <option value="其他">🔖 其他</option>
                        </select>
                    </div>

                    <div class="input-row">
                        <div>
                            <label for="prioritySelect">優先級</label>
                            <select id="prioritySelect">
                                <option value="高">🔴 高</option>
                                <option value="中" selected>🟡 中</option>
                                <option value="低">🟢 低</option>
                            </select>
                        </div>

                        <div>
                            <label for="dueDateInput">截止日期</label>
                            <input type="date" id="dueDateInput">
                        </div>
                    </div>
                </div>

                <div class="button-group">
                    <button class="btn-add" onclick="addTask()">➕ 新增任務</button>
                    <button class="btn-reset" onclick="resetForm()">🔄 重設</button>
                </div>

                <!-- 統計資訊 -->
                <div class="stats">
                    <div class="stat-box">
                        <div class="number" id="totalTasks">0</div>
                        <div class="label">總任務數</div>
                    </div>
                    <div class="stat-box">
                        <div class="number" id="completedTasks">0</div>
                        <div class="label">已完成</div>
                    </div>
                    <div class="stat-box">
                        <div class="number" id="pendingTasks">0</div>
                        <div class="label">待完成</div>
                    </div>
                </div>
            </div>

            <!-- 右側：任務列表 -->
            <div class="card">
                <h2>📋 任務列表</h2>

                <div class="filter-group">
                    <button class="filter-btn active" onclick="filterTasks('all')">全部</button>
                    <button class="filter-btn" onclick="filterTasks('pending')">⏳ 待完成</button>
                    <button class="filter-btn" onclick="filterTasks('completed')">✅ 已完成</button>
                    <button class="filter-btn" onclick="filterTasks('今天')">今天</button>
                    <button class="filter-btn" onclick="filterTasks('高')">🔴 高優先</button>
                </div>

                <div class="tasks-list tasks-scroll" id="tasksList">
                    <div class="empty-state">
                        <div style="font-size: 3rem; margin-bottom: 10px;">📭</div>
                        <p>還沒有任務，開始計畫你的一天吧！</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 編輯任務 Modal -->
    <div class="modal" id="editModal">
        <div class="modal-content">
            <div class="modal-header">編輯任務</div>
            <div class="input-group">
                <div>
                    <label for="editTaskInput">任務標題</label>
                    <input type="text" id="editTaskInput" maxlength="100">
                </div>

                <div>
                    <label for="editCategorySelect">分類</label>
                    <select id="editCategorySelect">
                        <option value="工作">🏢 工作</option>
                        <option value="學習">📚 學習</option>
                        <option value="健康">💪 健康</option>
                        <option value="生活">🏠 生活</option>
                        <option value="購物">🛍️ 購物</option>
                        <option value="娛樂">🎮 娛樂</option>
                        <option value="其他">🔖 其他</option>
                    </select>
                </div>

                <div class="input-row">
                    <div>
                        <label for="editPrioritySelect">優先級</label>
                        <select id="editPrioritySelect">
                            <option value="高">🔴 高</option>
                            <option value="中">🟡 中</option>
                            <option value="低">🟢 低</option>
                        </select>
                    </div>

                    <div>
                        <label for="editDueDateInput">截止日期</label>
                        <input type="date" id="editDueDateInput">
                    </div>
                </div>
            </div>

            <div class="modal-buttons">
                <button class="btn-cancel" onclick="closeEditModal()">取消</button>
                <button class="btn-save" onclick="saveEditTask()">保存</button>
            </div>
        </div>
    </div>

    <script>
        // ============ 資料管理 ============
        let tasks = [];
        let currentFilter = 'all';
        let editingTaskId = null;

        // 初始化應用
        function init() {
            loadTasks();
            renderTasks();
            updateStats();
        }

        // ============ 本地存儲操作 ============
        /**
         * 保存任務到本地存儲
         */
        function saveTasks() {
            localStorage.setItem('tasks', JSON.stringify(tasks));
        }

        /**
         * 從本地存儲載入任務
         */
        function loadTasks() {
            const savedTasks = localStorage.getItem('tasks');
            tasks = savedTasks ? JSON.parse(savedTasks) : [];
        }

        // ============ 任務操作 ============
        /**
         * 新增任務
         */
        function addTask() {
            const title = document.getElementById('taskInput').value.trim();
            const category = document.getElementById('categorySelect').value;
            const priority = document.getElementById('prioritySelect').value;
            const dueDate = document.getElementById('dueDateInput').value;

            // 驗證
            if (!title) {
                alert('請輸入任務標題');
                return;
            }

            // 建立任務物件
            const task = {
                id: Date.now(),
                title: title,
                category: category,
                priority: priority,
                dueDate: dueDate,
                completed: false,
                createdAt: new Date().toLocaleDateString('zh-TW')
            };

            tasks.push(task);
            saveTasks();
            renderTasks();
            updateStats();
            resetForm();
        }

        /**
         * 刪除任務
         * @param {number} id - 任務ID
         */
        function deleteTask(id) {
            if (confirm('確定要刪除這個任務嗎？')) {
                tasks = tasks.filter(task => task.id !== id);
                saveTasks();
                renderTasks();
                updateStats();
            }
        }

        /**
         * 切換任務完成狀態
         * @param {number} id - 任務ID
         */
        function toggleTask(id) {
            const task = tasks.find(t => t.id === id);
            if (task) {
                task.completed = !task.completed;
                saveTasks();
                renderTasks();
                updateStats();
            }
        }

        /**
         * 打開編輯 Modal
         * @param {number} id - 任務ID
         */
        function openEditModal(id) {
            editingTaskId = id;
            const task = tasks.find(t => t.id === id);

            if (task) {
                document.getElementById('editTaskInput').value = task.title;
                document.getElementById('editCategorySelect').value = task.category;
                document.getElementById('editPrioritySelect').value = task.priority;
                document.getElementById('editDueDateInput').value = task.dueDate;
                document.getElementById('editModal').classList.add('active');
            }
        }

        /**
         * 關閉編輯 Modal
         */
        function closeEditModal() {
            document.getElementById('editModal').classList.remove('active');
            editingTaskId = null;
        }

        /**
         * 保存編輯的任務
         */
        function saveEditTask() {
            if (!editingTaskId) return;

            const task = tasks.find(t => t.id === editingTaskId);
            if (task) {
                task.title = document.getElementById('editTaskInput').value.trim();
                task.category = document.getElementById('editCategorySelect').value;
                task.priority = document.getElementById('editPrioritySelect').value;
                task.dueDate = document.getElementById('editDueDateInput').value;

                saveTasks();
                renderTasks();
                updateStats();
                closeEditModal();
            }
        }

        // ============ 篩選和顯示 ============
        /**
         * 篩選任務
         * @param {string} type - 篩選類型
         */
        function filterTasks(type) {
            currentFilter = type;

            // 更新按鈕樣式
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');

            renderTasks();
        }

        /**
         * 獲取篩選後的任務列表
         */
        function getFilteredTasks() {
            let filtered = tasks;

            switch (currentFilter) {
                case 'pending':
                    filtered = tasks.filter(t => !t.completed);
                    break;
                case 'completed':
                    filtered = tasks.filter(t => t.completed);
                    break;
                case '今天':
                    const today = new Date().toISOString().split('T')[0];
                    filtered = tasks.filter(t => t.dueDate === today);
                    break;
                case '高':
                    filtered = tasks.filter(t => t.priority === '高');
                    break;
            }

            // 按優先級和日期排序
            return filtered.sort((a, b) => {
                const priorityOrder = { '高': 0, '中': 1, '低': 2 };
                if (priorityOrder[a.priority] !== priorityOrder[b.priority]) {
                    return priorityOrder[a.priority] - priorityOrder[b.priority];
                }
                if (a.dueDate && b.dueDate) {
                    return new Date(a.dueDate) - new Date(b.dueDate);
                }
                return 0;
            });
        }

        /**
         * 渲染任務列表
         */
        function renderTasks() {
            const tasksList = document.getElementById('tasksList');
            const filtered = getFilteredTasks();

            if (filtered.length === 0) {
                tasksList.innerHTML = `
                    <div class="empty-state">
                        <div style="font-size: 3rem; margin-bottom: 10px;">📭</div>
                        <p>沒有任務符合篩選條件</p>
                    </div>
                `;
                return;
            }

            tasksList.innerHTML = filtered.map(task => `
                <div class="task-item ${task.completed ? 'completed' : ''}">
                    <div class="checkbox-wrapper">
                        <input type="checkbox" 
                               ${task.completed ? 'checked' : ''} 
                               onchange="toggleTask(${task.id})">
                    </div>
                    <div class="task-content">
                        <h3>${escapeHtml(task.title)}</h3>
                        <div class="task-meta">
                            <span class="badge badge-category">${task.category}</span>
                            <span class="badge badge-priority ${task.priority.toLowerCase()}">${getPriorityIcon(task.priority)} ${task.priority}</span>
                            ${task.dueDate ? `<span class="badge badge-date">📅 ${formatDate(task.dueDate)}</span>` : ''}
                        </div>
                    </div>
                    <div class="task-actions">
                        <button class="btn-small btn-edit" onclick="openEditModal(${task.id})">編輯</button>
                        <button class="btn-small btn-delete" onclick="deleteTask(${task.id})">刪除</button>
                    </div>
                </div>
            `).join('');
        }

        /**
         * 更新統計資訊
         */
        function updateStats() {
            const total = tasks.length;
            const completed = tasks.filter(t => t.completed).length;
            const pending = total - completed;

            document.getElementById('totalTasks').textContent = total;
            document.getElementById('completedTasks').textContent = completed;
            document.getElementById('pendingTasks').textContent = pending;
        }

        // ============ 工具函數 ============
        /**
         * 重設表單
         */
        function resetForm() {
            document.getElementById('taskInput').value = '';
            document.getElementById('categorySelect').value = '工作';
            document.getElementById('prioritySelect').value = '中';
            document.getElementById('dueDateInput').value = '';
            document.getElementById('taskInput').focus();
        }

        /**
         * 格式化日期
         * @param {string} dateStr - 日期字符串
         */
        function formatDate(dateStr) {
            if (!dateStr) return '';
            const date = new Date(dateStr + 'T00:00:00');
            return date.toLocaleDateString('zh-TW', { month: '2-digit', day: '2-digit' });
        }

        /**
         * 取得優先級圖標
         * @param {string} priority - 優先級
         */
        function getPriorityIcon(priority) {
            const icons = { '高': '🔴', '中': '🟡', '低': '🟢' };
            return icons[priority] || '🔖';
        }

        /**
         * 轉義HTML特殊字符
         * @param {string} text - 文本
         */
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        /**
         * 支持鍵盤快捷鍵
         */
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && document.getElementById('taskInput') === document.activeElement) {
                addTask();
            }
            if (e.key === 'Escape') {
                closeEditModal();
            }
        });

        // 應用初始化
        init();
    </script>
</body>
</html>
